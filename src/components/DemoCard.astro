---
import Link from '@/components/Link.astro'
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  href: string
  description?: string
}

const { title, href, description } = Astro.props
const isComingSoon = !href || href === ''
---

<div
  class="hover:bg-secondary/50 border p-6 transition-colors duration-300 ease-in-out rounded-lg group"
>
  {isComingSoon ? (
    <div class="flex flex-col gap-3 cursor-not-allowed opacity-60">
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-lg font-medium leading-tight">{title}</h3>
        <Icon name="lucide:clock" class="size-5 text-muted-foreground shrink-0 mt-0.5" />
      </div>
      {description && (
        <p class="text-muted-foreground text-sm">{description}</p>
      )}
      {!description && (
        <p class="text-muted-foreground text-sm italic">Coming soon...</p>
      )}
    </div>
  ) : (
    <Link
      href={href}
      class="flex flex-col gap-3"
      external
    >
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-lg font-medium leading-tight group-hover:text-primary transition-colors">
          {title}
        </h3>
        <Icon 
          name="lucide:external-link" 
          class="size-5 text-muted-foreground group-hover:text-primary transition-all shrink-0 mt-0.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" 
        />
      </div>
      {description && (
        <p class="text-muted-foreground text-sm">{description}</p>
      )}
      <div class="flex items-center gap-2 text-xs text-muted-foreground/70">
        <Icon name="lucide:box" class="size-3.5" />
        <span>Interactive ThreeJS Demo</span>
      </div>
    </Link>
  )}
</div>
