---
import Link from '@/components/Link.astro'
import { Separator } from '@/components/ui/separator'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import VisitorCount from './VisitorCount.tsx'

interface Props {
  title: string
  slug: string
  description: string
  dateRange: string
  photoCount: number
  coverImage?: ImageMetadata
}

const { title, slug, description, dateRange, photoCount, coverImage } = Astro.props
---

<div
  class="hover:bg-secondary/50 border p-4 transition-colors duration-300 ease-in-out"
>
  <Link
    href={`/gallery/${slug}`}
    class="flex flex-col gap-4 sm:flex-row"
  >
    {
      coverImage && (
        <div class="max-w-3xs sm:shrink-0">
          <Image
            src={coverImage}
            alt={title}
            width={1200}
            height={630}
            class="object-cover rounded"
          />
        </div>
      )
    }

    <div class="grow">
      <h3 class="mb-2 text-lg leading-6 font-medium">{title}</h3>
      <p class="text-muted-foreground mb-2 text-sm">{description}</p>

      <div
        class="text-muted-foreground mb-2 flex flex-wrap items-center gap-x-2 text-xs"
      >
        <span>{dateRange}</span>
        <Separator orientation="vertical" className="h-4!" />
        <span class="flex items-center gap-x-1">
          <Icon name="lucide:image" class="size-3" />
          <span>{photoCount}</span>
        </span>
        <Separator orientation="vertical" className="h-4!" />
        <VisitorCount path={`/gallery/${slug}`} trackView={false} client:load />
      </div>
    </div>
  </Link>
</div>
