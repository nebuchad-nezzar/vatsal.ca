---
import { cn } from '@/lib/utils'

interface Book {
  title: string
  author: string
  cover?: string
  status: 'reading' | 'completed' | 'want'
  progress?: number // percentage for reading books
  amazonUrl?: string
  appleBooksUrl?: string
}

interface BookCardProps {
  book: Book
}

const { book } = Astro.props

const statusConfig = {
  reading: {
    label: 'Reading',
    color: 'bg-blue-500',
  },
  completed: {
    label: 'Done',
    color: 'bg-green-500',
  },
  want: {
    label: 'Want',
    color: 'bg-gray-600',
  },
}

const config = statusConfig[book.status as keyof typeof statusConfig]
---

<div class="group relative">
  <div class="relative aspect-[2/3] overflow-hidden rounded-lg border border-border bg-muted">
    {book.cover ? (
      <img
        src={book.cover}
        alt={book.title}
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center p-4 text-center">
        <div>
          <p class="font-semibold text-sm mb-1">{book.title}</p>
          <p class="text-xs text-muted-foreground">{book.author}</p>
        </div>
      </div>
    )}
    
    <!-- Status Badge -->
    <div class="absolute top-2 right-2">
      <span class={cn(
        "px-2 py-1 rounded text-xs font-medium text-white",
        config.color
      )}>
        {book.progress ? `${book.progress}%` : config.label}
      </span>
    </div>
  </div>
  
  <!-- Book Info -->
  <div class="mt-2 space-y-1">
    <h3 class="font-medium text-sm leading-tight line-clamp-2">{book.title}</h3>
    <p class="text-xs text-muted-foreground">{book.author}</p>
    <!-- Affiliate Buttons -->
    <div class="flex gap-2 pt-1.5">
      <a
        href={book.amazonUrl || '#'}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-[#131921] text-white text-xs font-medium leading-tight hover:bg-[#232f3e] transition-colors no-underline border border-[#333]"
      >
        <!-- Amazon "a" with orange swoosh -->
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
          <path d="M54.4 34.1c-11 .4-38.3 3.5-38.3 26.6 0 24.7 31.3 25.7 41.5 9.7 1.5 2.3 8 8.5 10.2 10.6l12.8-12.6s-7.7-6.2-7.7-12.4V25.8c0-5.7-5.5-18.6-25.4-18.6S17.2 19.6 17.2 30.8l16.6 1.5c3.7-11.2 12.3-11.2 12.3-11.2 9.2 0 9.2 8 8 15.6zM49.9 54.3c-6.8 4.8-13.3 4.8-13.3-3.3 0-8.2 6.7-12.3 13.3-13.3v16.6z" fill="white"/>
          <path d="M88.5 78.6c-1.6-2.5-13.1-1.2-18.1-.6-1.5.2-1.7-1.1-.4-2.1 8.8-6.2 23.4-4.4 25.1-2.3 1.7 2.1-.4 16.6-8.8 23.5-1.3 1.1-2.5.5-1.9-.9 1.9-4.6 5.6-15.1 4.1-17.6z" fill="#F90"/>
          <path d="M71.2 85.1C62.9 91.2 51.1 94.5 41 94.5c-14.4 0-27.3-5.3-37.1-14.1-.8-.7-.1-1.7.8-1.1 10.5 6.1 23.6 9.8 37.1 9.8 9.1 0 19.1-1.9 28.3-5.8 1.4-.6 2.6.9 1.1 1.8z" fill="#F90"/>
        </svg>
        <span class="flex flex-col leading-none">
          <span class="text-[8px] text-gray-400">Get it on</span>
          <span class="text-[11px] font-semibold">Amazon</span>
        </span>
      </a>
      <a
        href={book.appleBooksUrl || '#'}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-[#131921] text-white text-xs font-medium leading-tight hover:bg-[#232f3e] transition-colors no-underline border border-[#333]"
      >
        <!-- Apple Books app icon -->
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ab-bg" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#FBA835"/>
              <stop offset="100%" stop-color="#F5651F"/>
            </linearGradient>
          </defs>
          <rect width="120" height="120" rx="26" fill="url(#ab-bg)"/>
          <!-- Open book: left page -->
          <path d="M60 38v50c-8-4-18-6-28-6v-48c10 0 20 2 28 6z" fill="white" opacity="0.95"/>
          <!-- Open book: right page -->
          <path d="M60 38v50c8-4 18-6 28-6v-48c-10 0-20 2-28 6z" fill="white" opacity="0.85"/>
          <!-- Spine -->
          <rect x="58.5" y="34" width="3" height="54" rx="1.5" fill="white" opacity="0.5"/>
        </svg>
        <span class="flex flex-col leading-none">
          <span class="text-[8px] text-gray-400">Get it on</span>
          <span class="text-[11px] font-semibold">Apple Books</span>
        </span>
      </a>
    </div>
  </div>
</div>
