---

interface Tool {
  name: string
  description: string
  image?: string
  amazonUrl?: string
  category: string
}

interface Props {
  tool: Tool
}

const { tool } = Astro.props
---

<div class="hover:bg-secondary/50 border p-5 transition-colors duration-300 ease-in-out rounded-lg group flex gap-4">
  <!-- Image -->
  <div class="relative h-16 w-16 shrink-0 overflow-hidden rounded-md border border-border bg-muted">
    {tool.image ? (
      <img
        src={tool.image}
        alt={tool.name}
        class="h-full w-full object-cover"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-muted-foreground">
        <svg class="h-6 w-6 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="flex flex-col gap-2 min-w-0">
    <div>
      <h3 class="text-sm font-medium leading-tight">{tool.name}</h3>
      <p class="text-xs text-muted-foreground mt-1 line-clamp-2">{tool.description}</p>
    </div>
    <!-- Amazon Button -->
    {tool.amazonUrl !== undefined && (
      <div>
        <a
          href={tool.amazonUrl || '#'}
          target="_blank"
          rel="noopener noreferrer sponsored"
          class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-[#131921] text-white text-xs font-medium leading-tight hover:bg-[#232f3e] transition-colors no-underline border border-[#333]"
        >
          <!-- Amazon "a" with orange swoosh -->
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <path d="M54.4 34.1c-11 .4-38.3 3.5-38.3 26.6 0 24.7 31.3 25.7 41.5 9.7 1.5 2.3 8 8.5 10.2 10.6l12.8-12.6s-7.7-6.2-7.7-12.4V25.8c0-5.7-5.5-18.6-25.4-18.6S17.2 19.6 17.2 30.8l16.6 1.5c3.7-11.2 12.3-11.2 12.3-11.2 9.2 0 9.2 8 8 15.6zM49.9 54.3c-6.8 4.8-13.3 4.8-13.3-3.3 0-8.2 6.7-12.3 13.3-13.3v16.6z" fill="white"/>
            <path d="M88.5 78.6c-1.6-2.5-13.1-1.2-18.1-.6-1.5.2-1.7-1.1-.4-2.1 8.8-6.2 23.4-4.4 25.1-2.3 1.7 2.1-.4 16.6-8.8 23.5-1.3 1.1-2.5.5-1.9-.9 1.9-4.6 5.6-15.1 4.1-17.6z" fill="#F90"/>
            <path d="M71.2 85.1C62.9 91.2 51.1 94.5 41 94.5c-14.4 0-27.3-5.3-37.1-14.1-.8-.7-.1-1.7.8-1.1 10.5 6.1 23.6 9.8 37.1 9.8 9.1 0 19.1-1.9 28.3-5.8 1.4-.6 2.6.9 1.1 1.8z" fill="#F90"/>
          </svg>
          <span class="flex flex-col leading-none">
            <span class="text-[8px] text-gray-400">Get it on</span>
            <span class="text-[11px] font-semibold">Amazon</span>
          </span>
        </a>
      </div>
    )}
  </div>
</div>
