      <!-- Experience Timeline -->
  <section class="mt-8">
    <div class="mb-6">
      <h2 class="text-2xl font-semibold mb-2">Experience</h2>
      <p class="text-sm text-muted-foreground">
        4+ years in delivering in software, machine learning and AI enterpise solutions.
      </p>
    </div>
    
    <div class="space-y-6">
      {experience.map((exp, index) => (
        <div class="relative group">
          {index < experience.length - 1 && (
            <div class="absolute left-[15px] top-10 bottom-0 w-px bg-border group-hover:bg-primary/20 transition-colors" aria-hidden="true"></div>
          )}
          
          <div class="flex gap-4">
            <div class={cn(
              "relative flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center ring-4 ring-background z-10 overflow-hidden transition-all duration-300",
              exp.current ? "bg-primary text-primary-foreground shadow-lg shadow-primary/20" : "bg-muted text-muted-foreground group-hover:ring-primary/10"
            )}>
              {exp.logo ? (
                <img src={exp.logo} alt={exp.company} class="w-full h-full object-contain p-1 bg-white dark:bg-zinc-950" />
              ) : (
                <Icon name={exp.icon} class="size-4.5" />
              )}
            </div>
            
            <div class="flex-1 pb-6 min-w-0">
              <div class="mb-1">
                <h3 class="font-semibold text-lg leading-tight group-hover:text-primary transition-colors">{exp.role}</h3>
                <p class="text-sm text-muted-foreground">
                  {exp.companyUrl ? (
                    <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="hover:underline hover:text-foreground transition-all">
                      {exp.company}
                    </a>
                  ) : (
                    exp.company
                  )} · {exp.period}
                </p>
              </div>
              <p class="text-sm text-muted-foreground/90 leading-relaxed mt-2 italic border-l-2 border-border/50 pl-4 py-1 group-hover:border-primary/30 transition-colors">
                {exp.key}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
    </div>
  </section>

   
