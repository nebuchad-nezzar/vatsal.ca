---
import Layout from '../layouts/Layout.astro';
import PageHead from '../components/PageHead.astro';
---

<Layout>
  <PageHead slot="head" title="Now" />
  <div class="flex flex-col items-center justify-center min-h-[50vh] space-y-4">
    <h1 class="text-4xl font-bold">Now</h1>
    <p class="text-muted-foreground">See what I'm doing now...</p>
    <a href="/" class="text-sm underline hover:text-foreground/80">Back to Home</a>
  </div>
</Layout>
