    appleBooksUrl: "",
  },
  {
    title: "Psycho-Cybernetics",
    author: "Dr. Maxwell Maltz",
    status: "completed" as const,
    cover: "/books/cyber.png",
    amazonUrl: "",
    appleBooksUrl: "",
  },
  {
    title: "The Genome: Autobiography of a Species in 23 Chapters",
    author: "Matt Ridley",
    status: "want" as const,
    cover: "/books/genome.png",
    amazonUrl: "",
    appleBooksUrl: "",
  },
  {
    title: "Deep Work",
    author: "Cal Newport",
    status: "completed" as const,
